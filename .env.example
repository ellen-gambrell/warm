# Copy to ~/warm.care/.env on the server (never commit .env)

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-32-char-string
ENVIRONMENT=production

# Base URL for magic links in emails (no trailing slash)
MAGIC_LINK_BASE_URL=https://warm.care

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
# Leave RESEND_API_KEY blank → emails print to stdout (dev mode)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@warm.care

# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Local dev overrides ────────────────────────────────────────────────────────
# JWT_SECRET=dev-only-not-for-production
# ENVIRONMENT=development
# MAGIC_LINK_BASE_URL=http://localhost:5173
# RESEND_API_KEY=          ← leave blank → emails print to console
