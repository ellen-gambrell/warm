# warm.care backend — environment variables
# Copy to .env and fill in all values before starting the server.
# Never commit .env to version control.

# ── Auth ────────────────────────────────────────────────────────────────────
# Strong random secret used to sign JWTs. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret

# Set to "production" on the live server; anything else = dev mode
# (dev mode prints magic links to stdout instead of sending email)
ENVIRONMENT=production

# Base URL for magic links in emails — no trailing slash
MAGIC_LINK_BASE_URL=https://warm.care

# ── Email delivery (Resend) ──────────────────────────────────────────────────
# Get your API key at https://resend.com — use the warm.care sending domain
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Verified sending address on your Resend domain
FROM_EMAIL=noreply@warm.care

# ── Google OAuth (Drive + Gmail integration) ─────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Gemini (document synopsis) ───────────────────────────────────────────────
# Get your API key at https://aistudio.google.com
GEMINI_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── GIF search (Tenor) ───────────────────────────────────────────────────────
# Get your API key at https://developers.google.com/tenor
TENOR_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Monarch Money sync (optional, for Check Run) ─────────────────────────────
# Session token obtained by running: python3 sync_monarch.py --auth
# See docs/backlog-checkrun.md for full setup instructions.
MONARCH_TOKEN=
MONARCH_TOTP_SECRET=
